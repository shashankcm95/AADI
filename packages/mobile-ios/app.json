{
  "expo": {
    "name": "AADI",
    "slug": "aadi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_icon_stylized_square.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/logo_icon_stylized_square.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        },
        "NSLocationWhenInUseUsageDescription": "AADI needs your location to notify the restaurant when you're nearby.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "AADI uses background location to track your arrival and send updates to the kitchen.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "location",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.anonymous.aadi"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_icon_stylized_square.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/logo_icon_stylized_square.png"
    },
    "plugins": [
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "5cf75307-d2b7-4e69-ab11-34e240b096d8"
      }
    }
  }
}
