# ─── AADI Platform Secrets ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file — it is .gitignore'd.
#
# For production, store these in AWS SSM Parameter Store instead:
#   aws ssm put-parameter --name "/aadi/prod/OPENAI_API_KEY" --value "..." --type SecureString
#   aws ssm put-parameter --name "/aadi/prod/AWS_ACCESS_KEY_ID" --value "..." --type SecureString
#   aws ssm put-parameter --name "/aadi/prod/AWS_SECRET_ACCESS_KEY" --value "..." --type SecureString

OPENAI_API_KEY=sk-your-key-here
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here
AWS_REGION=us-east-1
